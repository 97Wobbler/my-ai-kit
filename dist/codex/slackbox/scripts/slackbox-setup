#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd "$(dirname "$0")" && pwd)

if command -v python3 >/dev/null 2>&1; then
  exec python3 "$SCRIPT_DIR/slackbox_cli.py" init "$@"
fi

if command -v python >/dev/null 2>&1; then
  exec python "$SCRIPT_DIR/slackbox_cli.py" init "$@"
fi

echo "Slackbox setup requires Python 3. Install Python 3 and try again." >&2
exit 127

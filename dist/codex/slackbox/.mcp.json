{
  "mcpServers": {
    "slackbox": {
      "command": "python3",
      "args": [
        "mcp/server.py"
      ],
      "cwd": ".",
      "env": {
        "SLACK_USER_TOKEN": "${SLACK_USER_TOKEN}",
        "SLACK_FETCH_DATA_DIR": "${SLACK_FETCH_DATA_DIR}",
        "PYTHONPATH": "mcp"
      }
    }
  }
}
